{
  "name": "glearning",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "pages:dev": "npm run build && wrangler pages dev dist --compatibility-date=2026-05-02",
    "deploy": "npm run build && wrangler pages deploy dist --project-name wuwa-bilingual-study"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.1.0",
    "wrangler": "^4.45.0"
  }
}
